{
  "name": "allekinos-cli",
  "version": "0.1.1",
  "description": "CLI wrapper for allekinos.de — look up cinema showtimes across Germany",
  "keywords": [
    "allekinos",
    "cinema",
    "cli",
    "germany",
    "kino",
    "showtimes"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/el-schneider/allekinos-cli.git"
  },
  "bin": {
    "allekinos": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run scripts/build.ts",
    "prepublishOnly": "bun run build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check ."
  },
  "dependencies": {
    "node-html-parser": "^7.1.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0"
  }
}
